# =============================================================================
# .env — Secret variables for the HNG anomaly detection stack
# NEVER commit this file to git. It is listed in .gitignore.
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=changeme_db_use_something_strong

# Nextcloud admin account
NC_ADMIN_USER=admin
NC_ADMIN_PASS=changeme_admin_use_something_strong

# Your VPS public IP (for Nextcloud trusted domains)
SERVER_IP=75.101.216.113

# Slack incoming webhook URL
# Create one at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=REDACTED_SLACK_WEBHOOK